---
{"dg-publish":true,"permalink":"/canvas-test.canvas/","contentClasses":"canvas-page","dg-note-properties":{}}
---

<div id="Canvas_Testcanvas" class="canvas-wrapper hide">
	<svg class="canvas-background">
		<defs>
			<pattern id="canvas-grid-Canvas_Testcanvas" width="25" height="25" patternUnits="userSpaceOnUse">
				<circle r="1.5" cx="12.5" cy="12.5"></circle>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#canvas-grid-Canvas_Testcanvas)"></rect>
	</svg>
	<div class="canvas">
		<svg class="canvas-edges-container" style="position:absolute;width:1px;height:1px;overflow:visible;">
			<defs><marker id="arrow-vartextmuted" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
			<path d="M0,0.5 L5,3 L0,5.5" fill="none" stroke="var(--text-muted)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
		</marker>
		<marker id="arrow-vartextmuted-start" markerWidth="6" markerHeight="6" refX="1" refY="3" orient="auto-start-reverse" markerUnits="strokeWidth">
			<path d="M6,0.5 L1,3 L6,5.5" fill="none" stroke="var(--text-muted)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
		</marker><filter x="-0.1" y="-0.1" width="1.2" height="1.3" id="edge-label-bg">
			<feFlood flood-color="var(--background-primary)" flood-opacity="1" result="bg"/>
			<feMerge>
				<feMergeNode in="bg"/>
				<feMergeNode in="SourceGraphic"/>
			</feMerge>
		</filter></defs><path d="M -180 -125 C 46.466774605017974 -125, 53 164.53322539498203, 53 391" fill="none" stroke="var(--text-muted)" stroke-width="2" class="canvas-edge" data-edge-id="d73fbffb1a29f2d0"  marker-end="url(#arrow-vartextmuted)" /><text x="21.42504047688174" y="48.07495952311826" class="canvas-edge-label" filter="url(#edge-label-bg)" fill="var(--text-muted)">Hello World</text>
<path d="M 253 591 C 396.34127109803376 591, 422 418.34127109803376, 422 275" fill="none" stroke="var(--text-muted)" stroke-width="2" class="canvas-edge" data-edge-id="04d9e5b89c41f1cb"  marker-end="url(#arrow-vartextmuted)" />
		</svg>
		<div class="canvas-node canvas-node-file " data-node-id="ed2788e5ef28fcdb" data-file-path="Selbstorganisation.md" style="transform: translate(222px, -125px); width: 400px; height: 400px; ">
	<div class="canvas-node-label">Selbstorganisation</div>
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-embed">
			<iframe src="/selbstorganisation//" class="canvas-file-iframe" loading="lazy"></iframe>
		</div>
	</div>
</div>
<div class="canvas-node canvas-node-file " data-node-id="374ab301ce4da8d7" data-file-path="Ralph loop.md" style="transform: translate(-147px, 391px); width: 400px; height: 400px; ">
	<div class="canvas-node-label">Ralph loop</div>
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-embed">
			<iframe src="/ralph-loop//" class="canvas-file-iframe" loading="lazy"></iframe>
		</div>
	</div>
</div>
<div class="canvas-node canvas-node-file " data-node-id="f23eab63be699779" data-file-path="Zettelkasten.md" style="transform: translate(-500px, -335px); width: 320px; height: 420px; ">
	<div class="canvas-node-label">Zettelkasten</div>
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-embed">
			<iframe src="/zettelkasten//" class="canvas-file-iframe" loading="lazy"></iframe>
		</div>
	</div>
</div>
	</div>
</div>
